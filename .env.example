# Dados de conexao com a catraca (mesma rede local desta maquina)
CATRACA_IP=192.168.0.130
CATRACA_USUARIO=admin
CATRACA_SENHA=

# Dominios do site que podem consumir esta API, separados por virgula.
# Em producao, NAO deixe como "*" - restrinja ao(s) dominio(s) reais.
# Ex: https://www.seusite.com.br,https://admin.seusite.com.br
ORIGENS_PERMITIDAS=*

# Pasta onde os CSVs gerados ficam salvos
PASTA_RELATORIOS=./relatorios

# Chave que o site deve enviar no header "X-API-Key" em toda requisicao.
# Gere uma chave forte com:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Token do Cloudflare Tunnel (ver README - secao Docker/Cloudflare Tunnel)
CLOUDFLARE_TUNNEL_TOKEN=
